@model IEnumerable<CetStudentBook.Models.CartItem>

@{
    ViewData["Title"] = "My Cart";
}

<h1>My Cart</h1>

@if (!Model.Any())
{
    <p>Your cart is empty.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Product Name</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Book?.Name</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.Quantity</td>
                    <td>@((item.Price * item.Quantity).ToString("C"))</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3" class="text-end"><strong>Grand Total:</strong></td>
                <td><strong>@Model.Sum(i => i.Price * i.Quantity).ToString("C")</strong></td>
            </tr>
        </tfoot>
    </table>

    <form asp-action="Buy" method="post">
        <button type="submit" class="btn btn-primary btn-lg">Buy</button>
    </form>
}

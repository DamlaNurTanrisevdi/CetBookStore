@model CetBookStore.Models.Book
@{
    ViewData["Title"] = "Kitap Sil";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h2 class="mb-4 fw-bold text-danger">Kitabı Sil</h2>
        
        <div class="alert alert-warning">
            Bu kitabı silmek istediğinize emin misiniz? Bu işlem geri alınamaz.
        </div>

        <div class="card p-4">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-4 text-center">
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="img-thumbnail" style="max-height: 200px;" />
                </div>
            }
            else
            {
                <div class="mb-4 text-center text-muted">
                    <div class="p-4 border rounded bg-light d-inline-block">
                        <i class="bi bi-image" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">Mevcut resim yok</p>
                    </div>
                </div>
            }
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">Kitap Adı</dt>
                <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.Title)</dd>

                <dt class="col-sm-4 text-muted">Kategori</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Category.Name)</dd>

                <dt class="col-sm-4 text-muted">Ücret</dt>
                <dd class="col-sm-8 fs-5 text-primary fw-bold">@Model.Price.ToString("C")</dd>
            </dl>
            
            <hr class="text-muted opacity-25">

            <div class="mt-2 text-end d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-link text-muted text-decoration-none">İptal, geri dön</a>
                <form asp-action="Delete" method="post" class="m-0">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger px-4 fw-bold">Evet, Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

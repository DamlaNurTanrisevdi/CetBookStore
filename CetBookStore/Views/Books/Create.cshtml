@model CetBookStore.Models.BookViewModel
@{
    ViewData["Title"] = "Kitap Ekleme";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h2 class="mb-4 fw-bold">Kitap Ekleme</h2>
        
        <div class="card p-4">
            <form asp-action="Create" enctype="multipart/form-data">
                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label text-muted">Kitap Resmi</label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label text-muted">Kitap Adı</label>
                    <input asp-for="Title" class="form-control form-control-lg" placeholder="Kitap adını giriniz..." />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label text-muted">Ücret</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg" placeholder="0.00" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label text-muted">Kategori</label>
                        <select asp-for="CategoryId" class ="form-select form-control-lg" asp-items="ViewBag.CategoryId">
                            <option value="">-- Kategori Seç --</option>
                        </select>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-primary btn-lg px-5">Kitabı Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

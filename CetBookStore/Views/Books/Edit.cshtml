@model CetBookStore.Models.BookViewModel
@{
    ViewData["Title"] = "Kitap Düzenle";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h2 class="mb-4 fw-bold">Kitap Düzenle</h2>
        
        <div class="card p-4">
            <form asp-action="Edit" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />
                
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-3 text-center">
                        <img src="@Model.ImageUrl" alt="Mevcut Resim" class="img-thumbnail" style="max-height: 200px;" />
                    </div>
                }
                else
                {
                    <div class="mb-3 text-center text-muted">
                        <div class="p-4 border rounded bg-light">
                            <i class="bi bi-image" style="font-size: 2rem;"></i>
                            <p class="mb-0 mt-2">Mevcut resim yok</p>
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label text-muted">Kitap Resmi (Yeni Seç)</label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label text-muted">Kitap Adı</label>
                    <input asp-for="Title" class="form-control form-control-lg" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label text-muted">Ücret</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label text-muted">Kategori</label>
                        <select asp-for="CategoryId" class ="form-select form-control-lg" asp-items="ViewBag.CategoryId">
                            <option value="">-- Kategori Seç --</option>
                        </select>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success btn-lg px-5">Güncelle</button>
                    <a asp-action="Index" class="btn btn-link text-muted">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

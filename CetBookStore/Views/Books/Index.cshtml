@model IEnumerable<CetBookStore.Models.Book>
@{
    ViewData["Title"] = "Kitaplar";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold m-0">Kitaplar</h2>
    <a asp-action="Create" class="btn btn-primary">Yeni Kitap Ekle</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5 rounded-3">
        <h4>Henüz kayıtlı kitap bulunmamaktadır.</h4>
        <p>Hemen "Yeni Kitap Ekle" butonuyla ilk kitabınızı oluşturabilirsiniz.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 p-3">
                    <div class="card-body p-2 d-flex flex-column">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top mb-3 rounded" alt="@item.Title" style="height: 200px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="card-img-top mb-3 rounded bg-light d-flex flex-column align-items-center justify-content-center text-muted" style="height: 200px;">
                                <i class="bi bi-image" style="font-size: 3rem;"></i>
                                <small>Resim Yok</small>
                            </div>
                        }
                        <h4 class="card-title fw-bold mb-1">@item.Title</h4>
                        <h6 class="text-muted mb-3">@Html.DisplayFor(modelItem => item.Category.Name)</h6>
                        
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fs-4 text-primary fw-bold">@item.Price.ToString("C")</span>
                            </div>
                            
                            <hr class="text-muted opacity-25">
                            
                            <div class="d-flex justify-content-between">
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-grow-1 me-2">
                                    <input type="hidden" name="bookId" value="@item.Id" />
                                    <button type="submit" class="btn btn-success w-100 fw-bold shadow-sm">Satın Al</button>
                                </form>
                                <div class="d-flex gap-1 border-start ps-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary d-flex align-items-center">Düzenle</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger d-flex align-items-center">Sil</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@model CetBookStore.Models.Category
@{
    ViewData["Title"] = "Kategori Sil";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h2 class="mb-4 fw-bold text-danger">Kategori Sil</h2>
        
        <div class="alert alert-warning">
            Bu kategoriyi silmek istediğinize emin misiniz?
        </div>

        <div class="card p-4">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">Kategori Adı</dt>
                <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.Name)</dd>
            </dl>
            
            <hr class="text-muted opacity-25">

            <div class="mt-2 text-end d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-link text-muted text-decoration-none">İptal</a>
                <form asp-action="Delete" method="post" class="m-0">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger px-4 fw-bold">Evet, Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

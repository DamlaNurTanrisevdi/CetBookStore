@model IEnumerable<CetBookStore.Models.Category>
@{
    ViewData["Title"] = "Kategoriler";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold m-0">Kategoriler</h2>
    <a asp-action="Create" class="btn btn-primary">Yeni Kategori Ekle</a>
</div>

<div class="card p-3 shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td class="fs-5 fw-medium ps-3">@item.Name</td>
                    <td class="text-end pe-3">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger ms-1">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

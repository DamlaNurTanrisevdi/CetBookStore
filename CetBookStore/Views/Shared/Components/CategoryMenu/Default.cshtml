@model IEnumerable<CetBookStore.Models.Category>

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        Categories
    </a>
    <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
        <li><a class="dropdown-item" asp-controller="Books" asp-action="Index">All Categories</a></li>
        <li><hr class="dropdown-divider"></li>
        @foreach (var category in Model)
        {
            <li><a class="dropdown-item" asp-controller="Books" asp-action="Index" asp-route-categoryId="@category.Id">@category.Name</a></li>
        }
    </ul>
</li>

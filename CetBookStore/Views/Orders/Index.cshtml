@model IEnumerable<CetBookStore.Models.Order>
@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <h2 class="fw-bold mb-4">Siparişlerim</h2>

        @if (!Model.Any())
        {
            <div class="card p-5 text-center mt-3 bg-light">
                <h4 class="text-muted">Henüz Siparişiniz Yok</h4>
            </div>
        }
        else
        {
            foreach (var order in Model)
            {
                <div class="card mb-4 shadow-sm border-0">
                    <div class="card-header bg-success text-white py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span><strong>Sipariş No:</strong> #@order.Id</span>
                            <span>@order.OrderDate.ToString("g")</span>
                        </div>
                    </div>
                    <ul class="list-group list-group-flush">
                        @if (order.OrderItems != null)
                        {
                            foreach (var item in order.OrderItems)
                            {
                                <li class="list-group-item d-flex justify-content-between py-3">
                                    <span>@item.Book?.Title</span>
                                    <span class="fw-bold">@item.Price.ToString("C")</span>
                                </li>
                            }
                        }
                    </ul>
                    <div class="card-footer bg-light text-end py-3">
                        <span class="fs-5">Odenen Tutar: <strong class="text-primary fs-4 ms-2">@order.TotalAmount.ToString("C")</strong></span>
                    </div>
                </div>
            }
        }
    </div>
</div>
